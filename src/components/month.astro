---
import { Image } from "astro:assets";
import { format, getDaysInMonth } from "date-fns";
import { getPhotoFiles, getPhotoPageImage, getPhotos } from "../lib/photos";
import Square from "./square.astro";

interface Props {
  month: number;
  year: number;
}

const { month, year } = Astro.props;

const photos = getPhotos();
const photoFiles = getPhotoFiles();

const date = new Date(year, month - 1);

const daysInMonth = getDaysInMonth(date);
const fillDaysBefore = (new Date(year, month - 1, 1).getDay() + 6) % 7;
const fillDaysAfter = (7 - ((fillDaysBefore + daysInMonth) % 7)) % 7;

const title = format(date, "MMMM yyyy");
---

<div>
  <div class="border border-b-0 border-gray-300 px-2 py-1">
    <p class="font-bold">{title}</p>
  </div>

  <div class="grid grid-cols-7 border-t border-l border-gray-300">
    {Array.from({ length: fillDaysBefore }, () => <Square />)}
    {
      Array.from({ length: daysInMonth }, (_, i) => i + 1).map(async (day) => {
        const date = new Date(year, month - 1, day);
        const ymd = format(date, "yyyy-MM-dd");

        const photo = photos.find((photo) => photo.ymd === ymd);

        if (!photo) {
          return <Square ymd={ymd} />;
        }

        if (photo.extension === "mov") {
          return (
            <Square ymd={ymd}>
              <a href={`/${ymd}`}>
                <div class="flex items-center justify-center h-full bg-gray-300">
                  <div class="text-3xl">▶</div>
                </div>
              </a>
            </Square>
          );
        }

        const image = photoFiles[photo.filename]();
        const photoPageImage = await getPhotoPageImage(photo.filename);

        return (
          <Square ymd={ymd}>
            <a href={`/${ymd}`} data-prefetch-photo-src={photoPageImage.src}>
              <Image
                src={image}
                format="jpg"
                alt=""
                width={200}
                height={200}
                fit="cover"
              />
            </a>
          </Square>
        );
      })
    }
    {Array.from({ length: fillDaysAfter }, () => <Square />)}
  </div>
</div>

<script>
  const prefetchedPhotoSrcs = new Set<string>();

  function prefetchPhoto(src: string) {
    if (prefetchedPhotoSrcs.has(src)) {
      return;
    }

    prefetchedPhotoSrcs.add(src);

    const image = new Image();
    image.decoding = "async";
    image.src = src;
  }

  function prefetchLinkedPhoto(event: Event) {
    const target = event.target;

    if (!(target instanceof Element)) {
      return;
    }

    const link = target.closest<HTMLAnchorElement>("a[data-prefetch-photo-src]");
    const src = link?.dataset.prefetchPhotoSrc;

    if (src) {
      prefetchPhoto(src);
    }
  }

  document.addEventListener("pointerenter", prefetchLinkedPhoto, {
    capture: true,
  });
  document.addEventListener("focusin", prefetchLinkedPhoto);
</script>
